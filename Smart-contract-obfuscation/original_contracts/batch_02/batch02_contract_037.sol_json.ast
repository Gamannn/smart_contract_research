					"id" : 48,
					"name" : "FunctionDefinition",
					"src" : "2295:75:0"
				},
				{
					"attributes" : 
					{
						"documentation" : "Verify that the passed asset data can be handled by this adapter and given pool.\r\n\n     * @dev it's sufficient to use this only when creating a new swap -- all the other swap\r\nfunctions first check if the swap hash is valid, while a swap hash with invalid\r\nasset type wouldn't be created at all.\r\n\n     * @dev asset type is 2 bytes long, and it's at offset 32 in `assetData`'s memory (the first 32\r\nbytes are the data length). We load the word at offset 2 (it ends with the asset type bytes),\r\nand retrieve its last 2 bytes into a `uint16` variable.\r",
						"name" : "checkAssetTypeAndData",
						"visibility" : "internal"
					},
					"children" : 
					[
						{
							"children" : 
							[
								{
									"attributes" : 
									{
										"constant" : false,
										"name" : "assetData",
										"scope" : 72,
										"stateVariable" : false,
										"storageLocation" : "memory",
										"type" : "bytes",
										"value" : null,
										"visibility" : "internal"
									},
									"children" : 
									[
										{
											"attributes" : 
											{
												"name" : "bytes",
												"type" : "bytes"
											},
											"id" : 49,
											"name" : "ElementaryTypeName",
											"src" : "3027:5:0"
										}
									],
									"id" : 50,
									"name" : "VariableDeclaration",
									"src" : "3027:22:0"
								},
