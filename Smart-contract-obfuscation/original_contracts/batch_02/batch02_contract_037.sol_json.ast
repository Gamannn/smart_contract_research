				},
				{
					"attributes" : 
					{
						"documentation" : "Swap release, which transfers the crypto asset to the receiver and removes the swap from\r\nthe active swap mapping. Normally called by the swap's oracle after it confirms a matching\r\nwire transfer on pool's bank account. Can be also called by the pool, for example in case\r\nof a dispute, when the parties reach an agreement off-chain.\r\n\n     * Emits a `Released` or `PoolReleased` event with the swap's hash.\r",
						"implemented" : true,
						"isConstructor" : false,
						"kind" : "function",
						"name" : "release",
						"scope" : 887,
						"stateMutability" : "nonpayable",
