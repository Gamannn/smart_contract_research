				},
				{
					"attributes" : 
					{
						"documentation" : "Swap return, which transfers the crypto asset back to the sender and removes the swap from\r\nthe active swap mapping. Can be called by the sender or the swap's oracle, but only if the\r\nswap is not claimed, or was claimed but the escrow lock time expired.\r\n\n     * Emits a `Returned` event with the swap's hash.\r",
						"implemented" : true,
						"isConstructor" : false,
						"kind" : "function",
						"name" : "returnFunds",
						"scope" : 1057,
