				{
					"attributes" : 
					{
						"documentation" : "Given all valid swap details, returns its status. To check a swap with unset buyer,\r\nuse `0x0` as the `_receiver` address. The return can be:\r\n0: the swap details are invalid, swap doesn't exist, or was already released/returned.\r\n1: the swap was created, and is not claimed yet.\r\n>1: the swap was claimed, and the value is a timestamp indicating end of its lock time.\r",
						"implemented" : true,
						"isConstructor" : false,
						"kind" : "function",
