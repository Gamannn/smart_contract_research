				{
					"attributes" : 
					{
						"constant" : false,
						"documentation" : "@dev Decrease the amount of tokens that an owner allowed to a spender.\r\napprove should be called when allowed[_spender] == 0. To decrement\r\nallowed value is better to use this function to avoid 2 calls (and wait until\r\nthe first transaction is mined)\r\nFrom MonolithDAO Token.sol\r\n@param _spender The address which will spend the funds.\r\n@param _subtractedValue The amount of tokens to decrease the allowance by.\r",
						"implemented" : true,
						"isConstructor" : false,
						"modifiers" : 
