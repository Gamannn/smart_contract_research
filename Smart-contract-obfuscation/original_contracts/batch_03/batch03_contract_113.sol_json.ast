					"attributes" : 
					{
						"constant" : true,
						"documentation" : "@dev Function to check the amount of tokens that an owner allowed to a spender.\r\n@param _owner address The address which owns the funds.\r\n@param _spender address The address which will spend the funds.\r\n@return A uint256 specifing the amount of tokens still available for the spender.\r",
