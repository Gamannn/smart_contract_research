				{
					"attributes" : 
					{
						"constant" : false,
						"documentation" : "@notice Set allowance for other address and notify\r\n@dev Allows contract `_spender` to spend no more than `_value` tokens on your behalf, and then ping the contract about it\r\n@param _spender The contract address authorized to spend\r\n@param _value the max amount they can spend\r\n@param _extraData some extra information to send to the approved contract\r\n@return True if it is done without error\r",
						"implemented" : true,
						"isConstructor" : false,
